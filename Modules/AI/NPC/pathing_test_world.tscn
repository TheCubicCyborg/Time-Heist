resource_name = "test_cube"
script/source = "extends MeshInstance3D

@export var branch: bool = false

func interact():
	print(\"interacted with test_cube\")

func _process(delta):
	if Input.is_action_just_pressed(\"debug_button\"):
		branch = not branch
		print(\"branch is now \", branch)
"

